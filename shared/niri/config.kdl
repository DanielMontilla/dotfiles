// Niri configuration
// Based on the default config with adaptations from the hyprland configuration

// Source all configuration modules
include "input.kdl"
include "output.kdl"
include "keybinds.kdl"
include "layout.kdl"
include "environment.kdl"
include "window-rules.kdl"

input {
    keyboard {
        xkb {
            layout "us"
        }
        numlock
    }

    touchpad {
        tap
        drag false
        natural-scroll
        scroll-factor vertical=0.3 horizontal=0.5
    }

    mouse {
        // follow-mouse disabled as we use click-to-focus
    }
}

output "eDP-1" {
    mode "2880x1920@120"
    scale 2
}

cursor {
    xcursor-size 36
}

gestures {
    hot-corners {
        off
    }
}

spawn-at-startup "/home/daniel/dotfiles/shared/niri/screencast-restart.sh"
spawn-at-startup "/run/current-system/sw/bin/quickshell"



