// Layout configuration for niri
// Adapted from hyprland theme.conf

layout {
    background-color "#111111"

    gaps 4

    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 2
        active-color "#000000"
        inactive-color "#000000"
    }

    border {
        off
    }

    struts {
    }
}