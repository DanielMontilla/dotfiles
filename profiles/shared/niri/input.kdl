// Input configuration for niri
// Adapted from hyprland input.conf

input {
    keyboard {
        xkb {
            layout "us"
        }
        numlock
    }

    touchpad {
        tap
        drag false
        click-method "clickfinger"
        natural-scroll
        scroll-factor vertical=0.3 horizontal=0.5
        // accel-speed 0.2
        // accel-profile "flat"
    }

    mouse {
        // natural-scroll is handled per-device
    }

    trackpoint {
        // trackpoint settings
    }

    // Disable focus-follows-mouse for click-to-focus
    // focus-follows-mouse
}