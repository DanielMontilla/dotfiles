// Minimal niri configuration for louie
// Kept intentionally small to isolate startup issues.
// Add back modules (output.kdl, screencast.kdl, etc.) once niri launches cleanly.

include "input.kdl"
include "layout.kdl"
include "keybinds.kdl"

input {
    keyboard {
        xkb {
            layout "us"
        }
    }

    touchpad {
        tap
        natural-scroll
    }
}

layout {
    background-color "#111111"
    gaps 8
}

cursor {
    xcursor-size 24
}

// Export niri's display environment into systemd/dbus so user services
// (xdg-desktop-portal-*) can reach the Wayland display. Without this the GTK
// portal fails with "cannot open display", and every GUI app (Ghostty, Brave,
// ...) blocks on the timing-out portal. Must run before any GUI app/portal use.
spawn-at-startup "sh" "-c" "systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP && dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP"

// Warm up the Ghostty GTK/libadwaita instance once at login so opening a
// terminal later is instant (combined with gtk-single-instance in the config).
spawn-at-startup "ghostty" "--initial-window=false" "--gtk-single-instance=true" "--quit-after-last-window-closed=false"
